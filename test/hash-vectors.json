      "expected_eventHash": "sha256:3a0d64b160128315c4fdc452faec3abe9529da587d88dd1c444f97dd070686ca"
    },
    {
      "id": "empty-and-strings",
      "input": {
        "empty": {},
        "arr": [],
        "s": "",
        "quote": "he said \"hi\""
      },
      "expected_eventHash": "sha256:492baf6c5fe9f56e80a2143aa4e42f588ae5edf077ead9c9dec0d4dd62c17e78"
    }
  ]
}
